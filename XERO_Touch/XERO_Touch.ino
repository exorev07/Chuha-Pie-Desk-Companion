byte currentFrame = 0;
byte currentAnimation = 0; // 0=idle, 1=happy, 2=surprised, 3=sleepy, 4=love
unsigned long lastFrameTime = 0;
int frameDelay = 60; // ms between frames

// Touch sensor state
bool lastTouchState = false;
unsigned long lastTouchTime = 0;

// Animation sequences (frame ranges)
struct AnimationSequence {
  byte startFrame;
  byte endFrame;
  byte fps;
  bool loop;
};

