// Pointer array - you would add all 212 frames from XERO here
const unsigned char* allFrames[] = {
  frame_idle_1, SPI OLED
  if(!display.begin(SSD1306_SWITCHCAPVC
};

void setup() {
  Serial.begin(115200);
  Serial.println("XERO Touch Control Starting...");

  // Initialize I2C OLED
  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    for(;;);
  }

  // Setup touch sensor
  pinMode(TOUCH_PIN, INPUT);
  
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.setTextSize(2);
  display.setCursor(10, 20);
  display.println("XERO+Touch");
  display.display();
  delay(2000);

  Serial.println("Ready! Touch to change animation.");
}

void loop() {
  checkTouch();
  updateAnimation();
}

void checkTouch() {
  bool currentTouch = digitalRead(TOUCH_PIN);
  
  // Detect rising edge (touch event)
  if (currentTouch && !lastTouchState) {
    lastTouchTime = millis();
    
    // Cycle to next animation
    currentAnimation++;
    if (currentAnimation > 4) {
      currentAnimation = 0;
    }
    
    // Reset to start of new animation
    currentFrame = animations[currentAnimation].startFrame;
    frameDelay = 1000 / animations[currentAnimation].fps;
    
    Serial.print("Animation: ");
    Serial.println(currentAnimation);
    
    delay(200); // Debounce
  }
  
  lastTouchState = currentTouch;
}

void updateAnimation() {
  unsigned long currentTime = millis();
  
  // Check if it's time for next frame
  if (currentTime - lastFrameTime >= frameDelay) {
    lastFrameTime = currentTime;
    
    // Draw current frame (for demo, alternating between 2 frames)
    display.clearDisplay();
    
    // In full version, you'd do: display.drawBitmap(0, 0, allFrames[currentFrame], 128, 64, 1);
    // For demo, using simple frame selection
    if (currentAnimation == 0) {
      display.drawBitmap(0, 0, frame_idle_1, 128, 64, 1);
    } else {
      display.drawBitmap(0, 0, frame_happy, 128, 64, 1);
    }
    
    // Show animation name at bottom
    display.setTextSize(1);
    display.setCursor(30, 56);
    switch(currentAnimation) {
      case 0: display.print("IDLE"); break;
      case 1: display.print("HAPPY"); break;
      case 2: display.print("SURPRISED"); break;
      case 3: display.print("SLEEPY"); break;
      case 4: display.print("LOVE"); break;
    }
    
    display.display();
    
    // Advance frame
    currentFrame++;
    AnimationSequence anim = animations[currentAnimation];
    
    if (currentFrame > anim.endFrame) {
      if (anim.loop) {
        currentFrame = anim.startFrame;
      } else {
        // Animation finished, go back to idle
        if (currentAnimation != 0) {
          currentAnimation = 0;
          currentFrame = animations[0].startFrame;
          frameDelay = 1000 / animations[0].fps;
        }
      }
    }
  }
}
